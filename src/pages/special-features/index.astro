<Layout title="Special Features" description="Special features index for Lewis's Medical-Surgical Nursing 12th Edition — tables, boxes, and case studies with chapter and page references.">
  <h1 class="page-title">Special Features</h1>
  <p class="page-sub">
    A comprehensive index of tables, boxes, and case studies from
    <em>Lewis's Medical-Surgical Nursing</em>, 12th Edition, with chapter and page references.
  </p>

  <nav class="toc" aria-label="Feature categories">
    <h2 class="toc-heading">Jump to Section</h2>
    <ul class="toc-list">
      {featureSections.map((section) => (
        <li>
          <a href={`#${section.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}`}>
            {section.icon} {section.title}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  {featureSections.map((section) => (
    <section
      class="feature-section"
      id={section.title.toLowerCase().replace(/[^a-z0-9]+/g, '-')}
    >
      <h2 class="section-heading">
        <span class="section-icon">{section.icon}</span>
        {section.title}
      </h2>
      <ul class="feature-list">
        {section.items.map((item) => (
          <li>{item}</li>
        ))}
      </ul>
    </section>
  ))}
</Layout>

<style>
  .page-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .page-sub {
    color: var(--color-muted);
    margin-bottom: 2rem;
    max-width: 700px;
  }

  /* Table of Contents */
  .toc {
    background: var(--color-surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.25rem 1.5rem;
    margin-bottom: 2.5rem;
    border-left: 4px solid var(--color-accent);
  }

  .toc-heading {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    margin-bottom: 0.75rem;
  }

  .toc-list {
    list-style: none;
    columns: 2;
    column-gap: 2rem;
  }

  @media (max-width: 640px) {
    .toc-list { columns: 1; }
  }

  .toc-list li {
    margin-bottom: 0.35rem;
    break-inside: avoid;
  }

  .toc-list a {
    font-size: 0.88rem;
    color: var(--color-accent);
  }

  .toc-list a:hover { text-decoration: underline; }

  /* Feature Sections */
  .feature-section {
    margin-bottom: 2.5rem;
    background: var(--color-surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
    scroll-margin-top: 1rem;
  }

  .section-heading {
    background: var(--color-primary);
    color: #fff;
    padding: 0.75rem 1.25rem;
    font-size: 1rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  .section-icon { font-size: 1.1rem; }

  .feature-list {
    list-style: none;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    padding: 0.75rem 0;
    margin: 0;
  }

  .feature-list li {
    padding: 0.4rem 1.25rem;
    font-size: 0.88rem;
    color: var(--color-text);
    border-bottom: 1px solid #eaf0f6;
  }

  .feature-list li::before {
    content: "›";
    color: var(--color-accent);
    margin-right: 0.4rem;
    font-weight: bold;
  }

  .feature-list li:last-child { border-bottom: none; }
</style>
