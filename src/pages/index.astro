---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL;
---

<Layout title="Home">
  <section class="hero">
    <h1>Lewis's Medical-Surgical Nursing</h1>
    <p class="edition">12th Edition &mdash; Study Guide &amp; Reference Companion</p>
    <p class="intro">
      A comprehensive digital companion for students and educators using
      <em>Lewis's Medical-Surgical Nursing: Assessment and Management of Clinical Problems</em>.
      Browse chapter outlines, key concepts, and study resources.
    </p>
    <div class="cta">
      <a class="btn" href={`${base}chapters/`}>Browse Chapters</a>
      <a class="btn btn-outline" href={`${base}resources/`}>Study Resources</a>
    </div>
  </section>

  <section class="features">
    <div class="card">
      <span class="icon">📖</span>
      <h2>Chapter Outlines</h2>
      <p>Structured summaries of all major chapters covering pathophysiology, clinical manifestations, nursing management, and more.</p>
      <a href={`${base}chapters/`}>View chapters &rarr;</a>
    </div>
    <div class="card">
      <span class="icon">🩺</span>
      <h2>Key Concepts</h2>
      <p>Core nursing concepts, NCLEX-focused content, and clinical decision-making frameworks drawn from the textbook.</p>
      <a href={`${base}resources/`}>Explore resources &rarr;</a>
    </div>
    <div class="card">
      <span class="icon">📝</span>
      <h2>Study Tools</h2>
      <p>Glossary terms, concept maps, and review questions to reinforce understanding and prepare for exams.</p>
      <a href={`${base}resources/`}>Get started &rarr;</a>
    </div>
  </section>
</Layout>

<style>
  .hero {
    text-align: center;
    padding: 3rem 1rem 2.5rem;
  }

  .hero h1 {
    font-size: clamp(1.8rem, 4vw, 2.8rem);
    color: var(--color-primary);
    line-height: 1.2;
  }

  .edition {
    margin: 0.5rem 0 1rem;
    color: var(--color-accent);
    font-size: 1.05rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .intro {
    max-width: 680px;
    margin: 0 auto 2rem;
    color: var(--color-muted);
    font-size: 1.05rem;
  }

  .cta { display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap; }

  .btn {
    display: inline-block;
    background: var(--color-accent);
    color: #fff;
    padding: 0.65rem 1.5rem;
    border-radius: var(--radius);
    font-weight: 600;
    transition: background 0.2s;
  }
  .btn:hover { background: var(--color-primary); text-decoration: none; }

  .btn-outline {
    background: transparent;
    color: var(--color-accent);
    border: 2px solid var(--color-accent);
  }
  .btn-outline:hover { background: var(--color-accent); color: #fff; }

  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.5rem;
    margin-top: 1rem;
    padding-bottom: 2rem;
  }

  .card {
    background: var(--color-surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    padding: 1.75rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .card .icon { font-size: 2rem; }

  .card h2 {
    font-size: 1.15rem;
    color: var(--color-primary);
  }

  .card p { color: var(--color-muted); font-size: 0.95rem; flex: 1; }

  .card a { font-weight: 600; font-size: 0.9rem; }
</style>
