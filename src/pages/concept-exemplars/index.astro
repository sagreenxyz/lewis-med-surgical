---

<Layout title="Concept Exemplars" description="Concept exemplars organized by nursing concept category from Lewis's Medical-Surgical Nursing 12th Edition.">
  <h1 class="page-title">Concept Exemplars</h1>
  <p class="page-sub">
    Clinical conditions organized by core nursing concept from
    <em>Lewis's Medical-Surgical Nursing</em>, 12th Edition. Each concept is illustrated
    through representative disease exemplars to reinforce conceptual understanding.
  </p>

  <div class="concepts-grid">
    {concepts.map((concept) => (
      <div class="concept-card">
        <h2 class="concept-name">{concept.name}</h2>
        <ul class="conditions-list">
          {concept.conditions.map((condition) => (
            <li>{condition}</li>
          ))}
        </ul>
      </div>
    ))}
  </div>
</Layout>

<style>
  .page-title {
    font-size: clamp(1.6rem, 3vw, 2.2rem);
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .page-sub {
    color: var(--color-muted);
    margin-bottom: 2rem;
    max-width: 700px;
  }

  .concepts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
    padding-bottom: 2rem;
  }

  .concept-card {
    background: var(--color-surface);
    border-radius: var(--radius);
    box-shadow: var(--shadow);
    overflow: hidden;
  }

  .concept-name {
    background: var(--color-primary);
    color: #fff;
    padding: 0.65rem 1.1rem;
    font-size: 0.95rem;
    font-weight: 700;
    letter-spacing: 0.02em;
  }

  .conditions-list {
    list-style: none;
    padding: 0.5rem 0;
    margin: 0;
  }

  .conditions-list li {
    padding: 0.4rem 1.1rem;
    font-size: 0.9rem;
    color: var(--color-text);
    border-bottom: 1px solid #eaf0f6;
  }

  .conditions-list li:last-child {
    border-bottom: none;
  }

  .conditions-list li::before {
    content: "•";
    color: var(--color-accent);
    margin-right: 0.5rem;
    font-weight: bold;
  }
</style>
